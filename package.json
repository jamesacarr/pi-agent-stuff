{
  "name": "pi-agent-stuff",
  "version": "0.0.1",
  "description": "James' pi coding agent skills and extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesacarr/pi-agent-stuff.git"
  },
  "readme": "README.md",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "prepare": "husky",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p ./tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@commitlint/types": "^20.2.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.15",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  }
}
