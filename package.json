{
  "name": "pi-agent-stuff",
  "version": "0.0.1",
  "description": "James' pi coding agent skills and extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/jamesacarr/pi-agent-stuff.git"
  },
  "readme": "README.md",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "prepare": "husky",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p ./tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typebox": "^1.1.38",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  }
}
